{
  "rules": {
    "profiles": {
      ".read": "auth != null",
      ".indexOn": ["queryableName", "queryableEmail", "queryablePhone"],
      "$uid": {
        ".write": "$uid === auth.uid",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 100 && newData.val().toLowerCase() === newData.parent().child('queryableName').val()"
        },
        "queryableName": {
          ".validate": "newData.isString() && newData.val().length <= 100 && newData.val() === newData.parent().child('name').val().toLowerCase()"
        },
        "queryableEmail": {
          ".validate": "newData.isString() && (newData.val() === data.val() || (auth.token.email_verified === true && newData.val() === auth.token.email.toLowerCase()))"
        },
        "queryablePhone": {
          ".validate": "newData.isString() && newData.val().length <= 30 && newData.val().matches(/^[0-9]*$/)"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "phoneNumber": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "address": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "maxPeople": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
        },
        "savedLocations": {
          "$pushId": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
          }
        },
        "collection": {
          ".read": "$uid === auth.uid || (root.child('users').child(auth.uid).child('friends').child($uid).val() === true && root.child('users').child($uid).child('friends').child(auth.uid).val() === true)",
          "$pushId": {
            "id": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 200"
            },
            "thumbnail": {
              ".validate": "newData.isString() && newData.val().length <= 500"
            },
            "minplayers": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "maxplayers": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "minplaytime": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "maxplaytime": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "yearpublished": {
              ".validate": "newData.isString() && newData.val().length <= 10"
            },
            "categories": {
              "$index": {
                ".validate": "newData.isString() && newData.val().length <= 60"
              }
            },
            "publicNote": {
              ".validate": "newData.isString() && newData.val().length <= 2000"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "gameOpinions": {
          "$gameId": {
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 200"
            },
            "rating": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
            },
            "privateNote": {
              ".validate": "newData.isString() && newData.val().length <= 2000"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "friends": {
          "$friendId": {
            ".write": "auth != null && $friendId === auth.uid && (newData.exists() ? root.child('friendRequests').child(auth.uid).child($uid).exists() : true)",
            ".validate": "newData.val() === true"
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "friendRequests": {
      "$toUid": {
        ".read": "auth != null && $toUid === auth.uid",
        "$fromUid": {
          ".read": "auth != null && $fromUid === auth.uid",
          ".write": "auth != null && ((newData.exists() && $fromUid === auth.uid && !data.exists() && !root.child('blocked').child($toUid).child(auth.uid).exists()) || (!newData.exists() && $toUid === auth.uid))",
          ".validate": "newData.val() === 'pending'"
        }
      }
    },
    "blocked": {
      "$ownerUid": {
        ".read": "auth != null && $ownerUid === auth.uid",
        ".write": "auth != null && $ownerUid === auth.uid",
        "$blockedUid": {
          ".validate": "newData.val() === true"
        }
      }
    },
    "userGatherings": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        "$gatheringId": {
          ".write": "auth != null && ((!newData.exists() && $uid === auth.uid) || (root.child('gatherings').child($gatheringId).child('host').val() === auth.uid && (!newData.exists() || $uid === auth.uid || root.child('gatherings').child($gatheringId).child('guests').child($uid).exists())))",
          ".validate": "newData.val() === true"
        }
      }
    },
    "gatherings": {
      "$gatheringId": {
        ".read": "auth != null && (data.child('host').val() === auth.uid || data.child('guests').child(auth.uid).exists())",
        ".write": "auth != null && (data.exists() ? data.child('host').val() === auth.uid : newData.child('host').val() === auth.uid)",
        "state": {
          ".validate": "newData.val() === 'pending' || newData.val() === 'confirmed' || newData.val() === 'canceled'"
        },
        "datetime": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "timezone": {
          ".validate": "newData.isString() && newData.val().length <= 60"
        },
        "host": {
          ".validate": "newData.isString() && newData.val().length <= 128 && (!data.exists() || newData.val() === data.val())"
        },
        "initiator": {
          ".validate": "newData.isString() && (data.exists() ? newData.val() === data.val() : newData.val() === auth.uid)"
        },
        "maxGuests": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
        },
        "location": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "notes": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "guests": {
          "$guestUid": {
            ".write": "auth != null && $guestUid === auth.uid && data.exists()",
            ".validate": "(newData.val() === 'invited' || newData.val() === 'accepted' || newData.val() === 'declined') && ($guestUid === auth.uid || newData.val() === data.val() || (newData.val() === 'invited' && root.child('users').child($guestUid).child('friends').child(auth.uid).val() === true))"
          }
        },
        "games": {
          "$index": {
            "id": {
              ".validate": "newData.isString() && newData.val().length <= 20"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length <= 200"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "emailInvites": {
          "$inviteId": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 320"
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
